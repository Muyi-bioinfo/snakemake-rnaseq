# ============================================================
# RNA-seq 上游分析流程 — Apptainer 定义文件
# ============================================================
# 适用于 HPC 集群（不需要 root 权限）
#
# 构建方式 1（从 Docker Hub 拉取）:
#   apptainer build rnaseq-pipeline.sif docker://username/rnaseq-pipeline:latest
#
# 构建方式 2（从本地定义文件构建，需要 root 或 --fakeroot）:
#   apptainer build --fakeroot rnaseq-pipeline.sif containers/apptainer.def
#
# 构建方式 3（从本地 Docker 镜像转换）:
#   docker build -t rnaseq-pipeline:latest -f containers/Dockerfile .
#   apptainer build rnaseq-pipeline.sif docker-daemon://rnaseq-pipeline:latest
# ============================================================

Bootstrap: docker
From: continuumio/miniconda3:24.1.2-0

%post
    # ---- 系统依赖 ----
    apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
        procps \
        curl \
        wget \
        build-essential \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libtiff5-dev \
        libjpeg-dev \
        && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # ---- 配置 conda channels ----
    /opt/conda/bin/conda config --add channels bioconda
    /opt/conda/bin/conda config --add channels conda-forge
    /opt/conda/bin/conda config --set channel_priority strict

    # ---- R + Bioconductor ----
    /opt/conda/bin/conda install -y -q \
        r-base=4.3.2 \
        bioconductor-deseq2=1.42.0 \
        r-ggplot2=3.5.0 \
        r-pheatmap=1.0.12 \
        r-ggrepel=0.9.5 \
        r-readr=2.1.5 \
        r-dplyr=1.1.4 \
        r-tidyr=1.3.1 \
        r-jsonlite=1.8.8 \
        bioconductor-rtracklayer=1.62.0 \
        bioconductor-clusterprofiler=4.10.0 \
        bioconductor-enrichplot=1.22.0 \
        bioconductor-org.hs.eg.db=3.18.0 \
        bioconductor-org.mm.eg.db=3.18.0 \
        r-cowplot=1.1.3

    # ---- 命令行工具 ----
    /opt/conda/bin/conda install -y -q \
        fastqc=0.12.1 \
        trimmomatic=0.39 \
        hisat2=2.2.1 \
        samtools=1.18 \
        subread=2.0.6 \
        multiqc=1.21

    # ---- 清理 ----
    /opt/conda/bin/conda clean -afy

    # ---- 工作目录 ----
    mkdir -p /pipeline/workflow/{data/{raw,ref},scripts}
    mkdir -p /pipeline/{results,logs,benchmarks}
    chmod -R 777 /pipeline

%environment
    export PATH=/opt/conda/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    #!/bin/bash
    # 默认行为：显示已安装工具版本
    echo "=== RNA-seq Pipeline Container ==="
    echo ""
    echo "Installed tools:"
    echo "  FastQC:       $(fastqc --version 2>&1 | head -1)"
    echo "  Trimmomatic:  $(trimmomatic -version 2>&1 | head -1)"
    echo "  HISAT2:       $(hisat2 --version 2>&1 | head -1)"
    echo "  Samtools:     $(samtools --version 2>&1 | head -1)"
    echo "  featureCounts:$(featureCounts -v 2>&1 | head -1)"
    echo "  MultiQC:      $(multiqc --version 2>&1)"
    echo "  R:            $(R --version 2>&1 | head -1)"
    echo "  DESeq2:       $(Rscript -e 'packageVersion("DESeq2")' 2>&1)"
    echo "  clusterProfiler:   $(Rscript -e 'packageVersion(\"clusterProfiler\")' 2>&1)"
    echo ""
    echo "Run snakemake:"
    echo "  apptainer exec --bind \$(pwd):/pipeline rnaseq-pipeline.sif \\"
    echo "    snakemake -s workflow/Snakefile --software-deployment-method conda -j 8"

%labels
    Author pipeline-team
    Version 1.0.0
    Description "Snakemake RNA-seq upstream analysis pipeline: FastQC → Trimmomatic → HISAT2 → featureCounts → MultiQC → DESeq2 → clusterProfiler"

%help
    使用方法:
      # 交互式运行
      apptainer shell rnaseq-pipeline.sif

      # 执行单条命令
      apptainer exec rnaseq-pipeline.sif fastqc --help

      # 运行完整流程（绑定宿主机项目目录）
      apptainer exec --bind $(pwd):/pipeline \
                     rnaseq-pipeline.sif \
                     snakemake -s workflow/Snakefile --software-deployment-method conda -j 8
